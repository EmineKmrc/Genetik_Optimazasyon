# 🧬 Genetik Algoritma ile Akıllı Depo Raf Optimizasyonu

Bu projede, bir lojistik firmasına ait akıllı depoda kullanılan raf sisteminin yüksekliği ve derinliği, belirli fiziksel kısıtlar altında **Genetik Algoritma** kullanılarak optimize edilmiştir.

**Amaç:** Depo verimliliğini artırırken alan ve maliyet kısıtlarına uygun en iyi raf yerleşimini elde etmektir.


# Matematiksel Model
## 📌 Amaç Fonksiyonu ve Kısıtlar

**Fonksiyon:** $$f(x_1, x_2) = 4x_1 + 3x_2 - 0.5x_1x_2$$

- **$x_1$:** Raf yüksekliği
- **$x_2$:** Raf derinliği

**⚠️ Kısıtlar:**
1. $2 \leq x_1 \leq 6$
2. $1.5 \leq x_2 \leq 4$
3. $x_1 + x_2 \leq 8$

#Parametreler ve Fonksiyon Tanımları
import random
import numpy as np
import matplotlib.pyplot as plt

# =============================
# PARAMETRELER
# =============================
POPULASYON_BOYUTU = 50
NESIL_SAYISI = 100
MUTASYON_ORANI = 0.1

# =============================
# UYGUNLUK (FITNESS) FONKSİYONU
# =============================
def uygunluk_hesapla(birey):
    x1, x2 = birey
    # Kısıt kontrolleri
    if x1 < 2 or x1 > 6 or x2 < 1.5 or x2 > 4 or (x1 + x2) > 8:
        return 0
    # Amaç fonksiyonu
    return 4 * x1 + 3 * x2 - 0.5 * x1 * x2

def populasyon_olustur():
    return [[random.uniform(2, 6), random.uniform(1.5, 4)] for _ in range(POPULASYON_BOYUTU)]

def turnuva_secimi(populasyon):
    # Rastgele 3 birey seçip en iyisini döndürür
    adaylar = random.sample(list(populasyon), 3)
    return max(adaylar, key=uygunluk_hesapla)

def caprazlama(ebeveyn1, ebeveyn2):
    cocuk_x1 = (ebeveyn1[0] + ebeveyn2[0]) / 2
    cocuk_x2 = (ebeveyn1[1] + ebeveyn2[1]) / 2
    return [cocuk_x1, cocuk_x2]

def mutasyon_uygula(birey):
    if random.random() < MUTASYON_ORANI:
        birey[0] += random.uniform(-0.3, 0.3)
        birey[1] += random.uniform(-0.3, 0.3)
    return birey

#Algoritma Döngüsü
# Başlangıç popülasyonu
populasyon = populasyon_olustur()
en_iyi_uygunluklar = []
en_iyi_birey = None

for nesil in range(NESIL_SAYISI):
    yeni_populasyon = []
    while len(yeni_populasyon) < POPULASYON_BOYUTU:
        ebeveyn1 = turnuva_secimi(populasyon)
        ebeveyn2 = turnuva_secimi(populasyon)
        
        cocuk = caprazlama(ebeveyn1, ebeveyn2)
        cocuk = mutasyon_uygula(cocuk)
        yeni_populasyon.append(cocuk)
    
    populasyon = yeni_populasyon
    en_iyi_birey = max(populasyon, key=uygunluk_hesapla)
    en_iyi_uygunluklar.append(uygunluk_hesapla(en_iyi_birey))

print(f"✅ Optimizasyon Tamamlandı!")
print(f"En iyi raf yüksekliği (x1): {en_iyi_birey[0]:.4f} m")
print(f"En iyi raf derinliği (x2): {en_iyi_birey[1]:.4f} m")
print(f"Maksimum Verim Puanı: {uygunluk_hesapla(en_iyi_birey):.4f}")

#Sonuçların Görselleştirilmesi ve Analiz
plt.figure(figsize=(10, 5))
plt.plot(en_iyi_uygunluklar, color='teal', linewidth=2)
plt.xlabel("Nesil Sayısı")
plt.ylabel("En İyi Uygunluk Değeri")
plt.title("Genetik Algoritma Yakınsama Grafiği")
plt.grid(True, linestyle='--', alpha=0.7)
plt.show()




